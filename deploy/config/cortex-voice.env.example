# /etc/humanoid-robot/cortex-voice.env

# Adapter selection for each stage of the voice pipeline; each maps to an
# entry-point in humanoid_robot.{audio_in,audio_out,vad,asr,tts,wakeword}_adapters.
# HR_VOICE__STACK__AUDIO_IN__NAME=unitree_g1
# HR_VOICE__STACK__AUDIO_OUT__NAME=unitree_g1
# HR_VOICE__STACK__VAD__NAME=silero
# HR_VOICE__STACK__ASR__NAME=faster_whisper
# HR_VOICE__STACK__TTS__NAME=piper
# HR_VOICE__STACK__WAKE_WORD__NAME=openwakeword

# Model paths (mounted under /var/lib/humanoid-robot/models on the robot).
# HR_VOICE__STACK__ASR__CONFIG={"model_dir":"/var/lib/humanoid-robot/models/faster-whisper-large-v3-turbo-int8","compute_type":"int8"}
# HR_VOICE__STACK__TTS__CONFIG={"voice_path":"/var/lib/humanoid-robot/models/piper/ru_RU-irina-medium.onnx"}
# HR_VOICE__STACK__WAKE_WORD__CONFIG={"model_path":"/var/lib/humanoid-robot/models/openwakeword/hey_robot.onnx"}

# Session tuning.
# HR_VOICE__SESSION__LANGUAGE_HINT=ru
# HR_VOICE__SESSION__REQUIRE_WAKE_WORD=true
# HR_VOICE__SESSION__MIN_SPEECH_MS=200
# HR_VOICE__SESSION__SILENCE_HANG_MS=600
