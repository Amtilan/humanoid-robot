# /etc/humanoid-robot/cortex-core.env
#
# Copy to /etc/humanoid-robot/cortex-core.env and edit. systemd's
# EnvironmentFile= will pick up any subset — the .service file provides
# safe defaults for anything not set here.

# HTTP
# HR_HTTP__HOST=0.0.0.0  # pragma: allowlist secret
# HR_HTTP__PORT=8080

# Bearer auth on /api/v1/*.  Leave blank to keep the API open
# (dev-friendly default). Set to any string to require callers to send
# `Authorization: Bearer <token>`; the dashboard prompts for it and
# stores it in localStorage.  Rotate by editing this file and
# restarting core.
# HR_AUTH__TOKEN=

# NATS
# HR_NATS__SERVERS=["nats://127.0.0.1:4222"]

# Observability
# HR_OBSERVABILITY__LOG_LEVEL=INFO
# HR_OBSERVABILITY__TRACING_ENABLED=false
# HR_OBSERVABILITY__OTLP_ENDPOINT=http://127.0.0.1:4318/v1/traces

# Safety (see apps/core/src/humanoid_robot/core/settings.py for the full set)
# HR_SAFETY__WATCHDOG_TIMEOUT_S=5
# HR_SAFETY__COMMAND_TIMEOUT_S=3
# HR_SAFETY__MAX_LINEAR_SPEED_MPS=0.5
# HR_SAFETY__MAX_ANGULAR_RATE_RPS=1.0
# HR_SAFETY__TILT_MAX_PITCH_RAD=0.6
# HR_SAFETY__TILT_MAX_ROLL_RAD=0.6
# HR_SAFETY__MAX_TEMPERATURE_C=85
# HR_SAFETY__AUDIT_DB_PATH=/var/lib/humanoid-robot/safety_audit.sqlite
# HR_SAFETY__AUDIT_MAX_ROWS=100000
# HR_SAFETY__AUDIT_MAX_AGE_DAYS=30
