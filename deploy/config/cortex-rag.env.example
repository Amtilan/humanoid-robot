# /etc/humanoid-robot/cortex-rag.env

# LLM (Qwen via llama.cpp — GGUF quant lives under /var/lib/humanoid-robot/models)
# HR_RAG__LLM__ADAPTER=llamacpp
# HR_RAG__LLM__CONFIG={"model_path":"/var/lib/humanoid-robot/models/qwen3-8b-instruct-q5_k_m.gguf","context_size":4096,"gpu_layers":40}

# Embedder + reranker (BGE-M3).
# HR_RAG__EMBEDDER__CONFIG={"model_dir":"/var/lib/humanoid-robot/models/bge-m3"}
# HR_RAG__RERANKER__CONFIG={"model_dir":"/var/lib/humanoid-robot/models/bge-reranker-base"}

# Vector store (Qdrant).
# HR_RAG__VECTOR_STORE__CONFIG={"url":"http://127.0.0.1:6333","collection":"knowledge"}
