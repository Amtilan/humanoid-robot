# /etc/humanoid-robot/alertmanager.env
#
# Copy to /etc/humanoid-robot/alertmanager.env and uncomment the
# receiver you want. Alertmanager reads this file at container start
# via docker compose's env_file directive; no restart of alertmanager
# is needed for the FIRST activation, but re-editing after boot needs
# `docker compose --profile metrics restart alertmanager`.
#
# The default receiver is "log" — every firing alert is written to
# alertmanager's stdout with no external notification.

# Which receiver to route alerts through. See
# deploy/observability/alertmanager.yml for the full list.
# ALERTMANAGER_RECEIVER=log

# -------------------- Slack --------------------
# Create at https://api.slack.com/messaging/webhooks
# ALERTMANAGER_RECEIVER=slack
# Format: https://hooks.slack.com/services/<TEAM_ID>/<CHANNEL_ID>/<TOKEN>
# SLACK_WEBHOOK_URL=
# SLACK_CHANNEL=#humanoid-robot

# -------------------- Discord --------------------
# Discord webhook URL, must end in /slack for slack-format payloads.
# ALERTMANAGER_RECEIVER=discord
# Format: https://discord.com/api/webhooks/<CHANNEL_ID>/<TOKEN>/slack
# DISCORD_WEBHOOK_URL=

# -------------------- ntfy --------------------
# ntfy.sh or a self-hosted ntfy server. URL must include the topic.
# ALERTMANAGER_RECEIVER=ntfy
# NTFY_URL=https://ntfy.sh/humanoid-robot-alerts

# -------------------- Generic webhook --------------------
# Any HTTP endpoint that accepts alertmanager's JSON envelope.
# https://prometheus.io/docs/alerting/latest/configuration/#webhook_config
# ALERTMANAGER_RECEIVER=webhook
# WEBHOOK_URL=https://example.com/hooks/humanoid-robot
