# /etc/humanoid-robot/cortex-robot-adapter.env

# Adapter selection: unitree_g1_edu (real robot) or mock (bench testing)
# HR_ROBOT_ADAPTER__ADAPTER_NAME=unitree_g1_edu

# Adapter config passed through to the adapter's kwargs. For unitree_g1_edu
# these map onto UnitreeG1Settings.
# HR_ROBOT_ADAPTER__ADAPTER_CONFIG={"network_interface":"eth0","mic_source":"g1","hand_kind":"dex3","speaker_volume":90}

# TelemetryPump cadence in seconds.
# HR_ROBOT_ADAPTER__TELEMETRY_INTERVAL_S=5

# NATS
# HR_ROBOT_ADAPTER__NATS__SERVERS=["nats://127.0.0.1:4222"]
